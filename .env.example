# Database
DATABASE_URL=postgres://timebot:timebot_password@localhost:5432/timebot?sslmode=disable

# SMTP (used for magic-link sign-in emails and timecard notifications)
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# Twilio (reserved for future supervisor SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# App
APP_BASE_URL=http://localhost:8080
APP_ENV=dev
PORT=8080

# Local dev only: uncomment if running the Vite dev server separately
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# Admin bootstrap
ADMIN_EMAIL=your_admin_email@example.com
